.page--record_detail

  .ai-check-result
    display: inline-flex
    align-items: center
    flex-wrap: wrap
    gap: rem(6px)
    padding: rem(4px 10px)
    border-radius: rem(999px)
    font-size: rem($font-size-small)
    font-weight: 600
    border: 1px solid transparent

    &.is-ai
      background: #fff1f0
      border-color: #e38b8b
      color: #9f2c2c

    &.is-human
      background: #edf8f1
      border-color: #6fb38b
      color: #21633d

    &.is-other
      background: #f3f5f7
      border-color: #c7d0d9
      color: #4b5c6b

    .icon
      font-size: rem(14px)

  .record-status__meta
    padding-top: 0

  .record-status__meta-item
    display: flex
    align-items: center
    gap: rem(12px)
    flex-wrap: wrap

  .record-status__meta-label
    color: $text-2-color
    font-size: rem($font-size-small)
    font-weight: 600
    text-transform: uppercase
    letter-spacing: .04em

  .record-status__ai-score
    padding-left: rem(6px)
    border-left: 1px solid currentColor
    opacity: .9

  .compiler-text
    padding: rem(20px 0)
    font-size: rem($font-size-small)
    &:empty
      display: none

  .compiler-text-mask
    display: none

  .col--case
    width: rem(70px)

  .col--memory, .col--time
    width: rem(120px)

  .col--case, .col--status
    border-right: 1px solid $table-border-color
  
  .subtask
    background-color: #fff !important
    height: rem(30px)
    td
      padding-top: 0 
      padding-bottom: 0 

  +mobile()
    .record-status__meta-item
      align-items: flex-start

    .col--time
      width: rem(70px)

    .col--memory
      width: rem(100px)

// dont hide compiler text if compile error
.hasjs .collapsed #status:not([data-status="7"])
  .compiler-text
    max-height: rem(250px)
    overflow: hidden
    position: relative

  .compiler-text-mask, .compiler-text-mask p
    display: block
    position: absolute
    cursor: pointer
    bottom: 0
    left: 0
    right: 0
    z-index: 1

  .compiler-text-mask
    height: rem(50px)
    background-image: linear-gradient(to bottom, transparent, #ffffff 25px)
    p
      text-align: center
